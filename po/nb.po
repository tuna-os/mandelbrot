#: src/account_settings/encryption_page/mod.blp:11
msgid ""
"Allows you to verify other Matrix accounts and automatically trust their verified "
"sessions"
msgstr "Verifiser andre Matrix-kontoer og godta de verifiserte øktene deres"

#: src/account_settings/encryption_page/mod.blp:75
msgid "Account Recovery"
msgstr "Kontogjenoppretting"

#: src/account_settings/encryption_page/mod.blp:77
msgid ""
"Allows to fully recover your account with a recovery key or passphrase, if you ever "
"lose access to all your sessions"
msgstr ""
"Gjenopprett kontoen din med en nøkkel eller et passord hvis du mister tilgang til "
"alle øktene dine"

