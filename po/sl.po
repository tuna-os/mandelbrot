msgstr "Obnovitvenega ključa računa ni bilo mogoče ponastaviti"

#: src/components/crypto/recovery_setup_view.rs:544
msgid "Could not enable account recovery"
msgstr "Obnovitve računa ni bilo mogoče omogočiti"

