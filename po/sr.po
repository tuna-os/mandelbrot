msgstr "Не могу да приступим датотеци"

#: src/account_settings/encryption_page/import_export_keys_subpage.rs:244
msgid "Passphrases do not match"
msgstr "Фразе се не подударају"

#: src/account_settings/encryption_page/import_export_keys_subpage.rs:321
msgid "Room encryption keys exported successfully"
msgstr "Кључеви шифровања собе су успешно извезени"

#: src/account_settings/encryption_page/import_export_keys_subpage.rs:327
#, rust-format
msgid "Imported 1 room encryption key"
msgid_plural "Imported {n} room encryption keys"
msgstr[0] "Увезено је {n} кључ шифровања собе"
msgstr[1] "Увезена су {n} кључа шифровања собе"
msgstr[2] "Увезено је {n} кључева шифровања собе"
msgstr[3] "Увезено је {n} кључ шифровања собе"

#: src/account_settings/encryption_page/import_export_keys_subpage.rs:341
